{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GhostStackWorkflowSpec",
  "type": "object",
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^v[0-9]+\\.[0-9]+$"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "author": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    },
    "template_id": { "type": "string" },
    "variables": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string" },
          "action": { "type": "string" },
          "priority": { "type": "string", "enum": ["low", "normal", "high", "critical"] },
          "arguments": { "type": "object" },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["id", "title", "type", "action"]
      }
    }
  },
  "required": ["spec_version", "metadata", "template_id", "tasks"]
}
